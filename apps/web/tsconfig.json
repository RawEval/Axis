{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@axis/design-system": [
        "../../packages/design-system/src"
      ],
      "@axis/design-system/*": [
        "../../packages/design-system/src/*"
      ],
      "@axis/shared-types": [
        "../../packages/shared-types/src"
      ],
      "@axis/shared-types/*": [
        "../../packages/shared-types/src/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
