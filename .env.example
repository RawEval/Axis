# =============================================================================
# Axis — environment template
# =============================================================================
# Copy this file to `.env` (git-ignored) and fill in real values.
# Every variable below is referenced by at least one service. When you add a
# new service or feature, add its vars here AND in the relevant service's
# app/config.py Settings class.
#
# Priority (highest first):
#   1. .env.local        — per-developer override, git-ignored
#   2. .env              — local dev, git-ignored
#   3. .env.example      — this file, committed as template
# =============================================================================


# =============================================================================
# CORE
# =============================================================================
NODE_ENV=development
PYTHON_ENV=development
ENVIRONMENT=dev                                # dev | staging | prod
AXIS_REGION=ap-south-1                         # for data residency routing
LOG_LEVEL=info                                 # debug | info | warning | error
ENABLE_CONSOLE_LOG=true


# =============================================================================
# SERVICE URLS (local dev defaults — override per environment)
# =============================================================================
API_GATEWAY_URL=http://localhost:8000
AGENT_ORCHESTRATION_URL=http://localhost:8001
CONNECTOR_MANAGER_URL=http://localhost:8002
EVAL_ENGINE_URL=http://localhost:8003
MEMORY_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005
AUTH_SERVICE_URL=http://localhost:8006
WEB_APP_URL=http://localhost:3001


# =============================================================================
# FRONTEND (Next.js — must be NEXT_PUBLIC_* to reach the browser)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=Axis
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com


# =============================================================================
# DATABASES
# =============================================================================
POSTGRES_URL=postgresql://axis:axis@localhost:5433/axis
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER=redis://localhost:6379/1
REDIS_CELERY_BACKEND=redis://localhost:6379/2

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=axis

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=axis-dev-password
NEO4J_DATABASE=neo4j


# =============================================================================
# SECURITY & AUTH
# =============================================================================
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production-generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-32-bytes-base64

# Password policy
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Session
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_SECURE=false                    # set true in prod (HTTPS only)
SESSION_COOKIE_DOMAIN=localhost

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001


# =============================================================================
# LLM PROVIDERS
# =============================================================================

# --- Anthropic (PRIMARY — Sonnet for planning/writes, Haiku for everything else)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.2
ANTHROPIC_TIMEOUT_MS=120000

# --- OpenAI (fallback)
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Nvidia NIM (fallback — self-host OSS models)
NVIDIA_API_KEY=nvapi-your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# --- Google (Gemini fallback)
GOOGLE_API_KEY=AIzaSy-your-google-api-key
GOOGLE_MODEL=gemini-1.5-pro

# --- Groq (fast inference fallback)
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# --- Deepseek (cheap fallback for high-volume scoring)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# --- OpenRouter (universal gateway)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# --- Mistral
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest


# =============================================================================
# EMBEDDINGS (for Qdrant)
# =============================================================================
EMBEDDING_PROVIDER=voyage                       # voyage | openai | nvidia
VOYAGE_API_KEY=pa-your-voyage-api-key
VOYAGE_MODEL=voyage-3


# =============================================================================
# CONNECTOR SYNC (connector-manager background scheduler)
# =============================================================================
CONNECTOR_SYNC_ENABLED=true   # set to false to disable the adaptive sync scheduler


# =============================================================================
# CONNECTOR OAUTH — SLACK
# =============================================================================
# Create at: https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id.apps.slack.com
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_ID=Axxxxxxxxxxx
SLACK_BOT_SCOPES=channels:history,channels:read,chat:write,groups:history,groups:read,im:history,im:read,reactions:read,reactions:write,users:read
SLACK_USER_SCOPES=search:read
SLACK_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/slack/callback


# =============================================================================
# CONNECTOR OAUTH — NOTION
# =============================================================================
# Create at: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=secret_your-notion-client-secret
NOTION_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/notion/callback
NOTION_VERSION=2022-06-28


# =============================================================================
# CONNECTOR OAUTH — GOOGLE (Gmail + Drive + Calendar)
# =============================================================================
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar

# Gmail push notifications (Pub/Sub)
GMAIL_PUBSUB_TOPIC=projects/your-gcp-project/topics/axis-gmail
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-gcp-project/subscriptions/axis-gmail-sub

# Drive push notifications
GDRIVE_WEBHOOK_URL=https://your-public-domain/webhooks/gdrive


# =============================================================================
# CONNECTOR OAUTH — GITHUB
# =============================================================================
# Create at: https://github.com/settings/apps (OAuth App OR GitHub App)
GITHUB_CLIENT_ID=Iv1.your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/github/callback


# =============================================================================
# CONNECTOR OAUTH — LINEAR (Phase 2)
# =============================================================================
LINEAR_CLIENT_ID=your-linear-client-id
LINEAR_CLIENT_SECRET=lin_oauth_your-linear-client-secret
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
LINEAR_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/linear/callback


# =============================================================================
# CONNECTOR OAUTH — JIRA (Phase 2)
# =============================================================================
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/jira/callback


# =============================================================================
# CONNECTOR OAUTH — AIRTABLE (Phase 2)
# =============================================================================
AIRTABLE_CLIENT_ID=your-airtable-client-id
AIRTABLE_CLIENT_SECRET=your-airtable-client-secret
AIRTABLE_OAUTH_REDIRECT_URI=http://localhost:8002/oauth/airtable/callback


# =============================================================================
# STORAGE (document snapshots, fine-tuning datasets)
# =============================================================================
# Cloudflare R2 — preferred (no egress fees)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=axis-snapshots
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# AWS S3 (fallback / alt region)
AWS_ACCESS_KEY_ID=AKIA-your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET=axis-data


# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Apple Push Notification service (iOS)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.raweval.axis
APNS_PRIVATE_KEY_PATH=./secrets/apns.p8
APNS_PRODUCTION=false

# Firebase Cloud Messaging (Android)
FCM_PROJECT_ID=axis-mobile
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json

# Resend (transactional email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@raweval.com
RESEND_REPLY_TO=support@raweval.com

# Local SMTP (Mailhog in docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@axis.local


# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

POSTHOG_API_KEY=phc_your-posthog-api-key
POSTHOG_HOST=https://app.posthog.com

GRAFANA_URL=https://your-org.grafana.net
GRAFANA_API_KEY=


# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_FREE_PER_MIN=10
RATE_LIMIT_FREE_PER_DAY=50
RATE_LIMIT_PRO_PER_MIN=60
RATE_LIMIT_PRO_PER_DAY=500
RATE_LIMIT_TEAM_PER_MIN=120
RATE_LIMIT_TEAM_PER_DAY=2500
RATE_LIMIT_ENTERPRISE_PER_MIN=600


# =============================================================================
# REQUEST / TIMING
# =============================================================================
REQUEST_TIMEOUT_MS=30000
LONG_REQUEST_TIMEOUT_MS=120000
HTTP_CLIENT_TIMEOUT_MS=5000
MAX_RETRIES=3
RETRY_DELAY_MS=1000


# =============================================================================
# FILE PROCESSING
# =============================================================================
MAX_FILE_SIZE_BYTES=104857600
MAX_BATCH_FILE_SIZE=10
ALLOWED_FILE_TYPES=pdf,docx,md,txt,csv,json


# =============================================================================
# AGENT / PROACTIVE ENGINE LIMITS (spec §6.3, §6.7)
# =============================================================================
AGENT_MAX_CONCURRENT_SUBAGENTS=5
AGENT_MAX_TOKENS_PER_RUN=16000
AGENT_PLAN_TIMEOUT_SECONDS=30
AGENT_EXECUTION_TIMEOUT_SECONDS=180

PROACTIVE_MAX_SURFACES_PER_DAY=5
PROACTIVE_COLD_START_MIN_SIGNALS=10
PROACTIVE_DEDUPE_WINDOW_HOURS=72
PROACTIVE_MORNING_BRIEF_HOUR=8


# =============================================================================
# MEMORY (spec §6.4)
# =============================================================================
MEMORY_EPISODIC_DECAY_DAYS=90
MEMORY_COMPRESSION_HOUR=3                       # nightly UTC
MEMORY_MAX_RETRIEVAL_RESULTS=20


# =============================================================================
# EVAL ENGINE (spec §6.6)
# =============================================================================
EVAL_FLAG_THRESHOLD=3.0                         # composite score below = flagged
EVAL_DIMENSION_FLAG_THRESHOLD=2                 # any dimension below = flagged
EVAL_OPT_OUT_DEFAULT=true                       # users opt out of training by default


# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_PROACTIVE_LAYER=false                   # enables §6.3 surfaces
FEATURE_WRITE_BACK=true                         # enables §6.5 write actions
FEATURE_MULTI_AGENT=false                       # enables §6.7 multi-agent orchestration
FEATURE_ANALYTICS=true
FEATURE_FINE_TUNE_COLLECTION=false              # enables §6.6 long-loop dataset collection
FEATURE_MOBILE_PUSH=false                       # Phase 2
FEATURE_ENTERPRISE_SSO=false                    # Phase 3


# =============================================================================
# BILLING (Phase 2 — when paid signups open)
# =============================================================================
# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Stripe (international)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret


# =============================================================================
# SUPABASE (Phase 2 — managed auth + storage)
# =============================================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
